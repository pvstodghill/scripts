# Add a worksheet
sub import_data {
  my $workbook  = shift;
  my $title = shift;
  my $headers    = shift;
  my $data      = shift;
  my $worksheet = $workbook->add_worksheet($title);
  $worksheet->add_write_handler(qr[\w], \&store_string_widths);
  $worksheet->write('A1', $headers, ,$header_fmt);
  my $num_rows = 1;
  for my $row (@$data) {
    $worksheet->write($num_rows++, 0, $row);
  }
  set_columns_width($worksheet,$opt_a,$opt_w);

  if ( $opt_A ) {
    my $num_cols = scalar($headers->@*);
    $worksheet->autofilter(0,0,$num_rows-1,$num_cols-1);
    $worksheet->freeze_panes(1,0); # freeze first row
  }

  return $worksheet;
}


