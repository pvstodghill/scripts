sub usage {
  
  print "Usage: $0 [options] [sheet_title:file1.tsv file2.csv ...]\n";

  print "-A - add autofilter to all headers\n";
  print "-H - first line is _not_ header\n";
  print "-a - autofit column widths\n";
  print "-c - input is always CSV\n";
  print "-h - print this message and exit.\n";
  print "-o FILENAME - output file name [$opt_o]\n";
  print "-t - input is always TSV\n";
  print "-w NUM - maximum column width\n";

  print "\n";
  print "if -a and -w NUM are both specified, the min of each width is used.\n";
  print "-A and -H are mutually exclusive.\n";

  exit($_);
}

my $stat = getopts('AHacho:tw:');
if (!$stat || $opt_h) {
  usage($stat);
}

if ( scalar(@ARGV) == 0 ) {
  # Hail Mary!
  push @ARGV, "/dev/stdin";
}

if ($opt_A && $opt_H) {
  usage(1);
}
  

#(!$opt_H) || die "-H not implemented,";

my $outfile = $opt_o;
my $workbook = Excel::Writer::XLSX->new($outfile);

my $header_fmt = $workbook->add_format();
$header_fmt->set_bold(1);
$header_fmt->set_underline(1);

my $bold_fmt = $workbook->add_format();
$bold_fmt->set_bold(1);

foreach my $raw_infile ( @ARGV ) {
  my ($title,$infile);
  if ( $raw_infile =~ /^(.*):(.*)/ ) {
    ($title,$infile) = ($1,$2);
  } else {
    $title = basename($raw_infile,".tsv",".csv");
    $infile = $raw_infile;
  }
  if ($infile eq "-") {
    # Hail Mary!
    $infile = "/dev/stdin";
  }
  process_file($infile,$title,$workbook);
}

# Add a tsv file to the workbook
sub process_file {
  my ($infile,$title,$workbook) = @_;

  # my $parser = Text::CSV::Simple->new({sep_char => "\t", quote_char => undef});
  # my @data = $parser->read_file($infile);

  my @data;
  if ( $opt_t || $infile =~ /\.tsv$/ ) {
    open (my $fh,"<",$infile) || die "Cannot open: $infile";
    binmode($fh, ":utf8");
    while (<$fh>) {
      s/[\r\n]+$//;
      push @data, [ split("\t") ];
    }
    close($fh) || die;
  } elsif ( $opt_c || $infile =~ /\.csv$/ ) {
    use Text::CSV;
    my $csv = Text::CSV->new({ binary => 1 });
    open (my $fh,"<",$infile) || die "Cannot open: $infile";
    binmode($fh, ":utf8");
    while (<$fh>) {
      chomp;
      $_ =~ s/\r$//;
      my $status = $csv->parse($_);
      if (!$status) {
	$csv->error_diag();
	print $csv->error_input(),"\n";
	die;
      }
      push @data, [ $csv->fields() ];
    }
    close($fh) || die;
  } else {
    die "don't know how to process <<$infile>>,";
  }

  my $headers;
  if ($opt_H) {
    $headers = [];
  } else {
    $headers = shift @data;
  }

  import_data($workbook, $title, $headers, [@data]);
}

